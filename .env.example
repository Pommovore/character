# Configuration de l'API
SECRET_KEY=change_this_to_a_secure_random_string

# Compte administrateur (configuré via /setup au premier lancement)
ADMIN_EMAIL=

# Base de données
# DATABASE_URL=sqlite:///data/db/character.db

# Hugging Face API
HF_TOKEN=votre_token_huggingface_ici
# Modèles recommandés et testés (Serverless Inference API) :
# - Qwen/Qwen2.5-72B-Instruct
# - meta-llama/Llama-3.2-3B-Instruct
# - google/gemma-3-27b-it:featherless-ai
# - openai/gpt-oss-120b:groq
HF_MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Paramètres du serveur
# HOST=0.0.0.0
# PORT=8000

# Discord (optionnel) — pour recevoir des notifications
DISCORD_WEBHOOK_URL=

# Origines CORS autorisées (séparées par des virgules, ou * pour toutes)
# ALLOWED_ORIGINS=https://example.com
